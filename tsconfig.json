{
  "compilerOptions": {
    "outDir": "./dist/",
    "noImplicitAny": true,
    "module": "es2020",
    "target": "es2020",
    "jsx": "react",
    "allowJs": true,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "sourceMap": true,
    "strict": false
  },
  "exclude": ["node_modules", "dist"]
}
